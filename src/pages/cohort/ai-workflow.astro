---
import BaseHead from '../../components/BaseHead.astro';
import Nav from '../../components/Nav.astro';
import DiagonalBand from '../../components/DiagonalBand.astro';
import Footer from '../../components/Footer.astro';
import FAQ from '../../components/FAQ.astro';

const cohortStartLabel = 'June 2026';

const principles = [
  { num: '01', name: 'Planning' },
  { num: '02', name: 'Stages' },
  { num: '03', name: 'Handoffs' },
  { num: '04', name: 'Humans' },
  { num: '05', name: 'Dependencies' },
  { num: '06', name: 'Bounded Roles' },
  { num: '07', name: 'Quality Gates' },
  { num: '08', name: 'Portability' },
];

const outcomes = [
  'A working AI workflow architecture document for <em>your</em> codebase. Not a template, yours.',
  'Defined planning, execution, and review stages with explicit handoffs between each.',
  'A library of bounded sub-agent roles you’ve designed for your stack.',
  'Pre- and post-implementation review gates wired into your tooling.',
  'A portability spec, so your workflow lifts cleanly to the next codebase you touch.',
  'Five weeks of working through it with Mark + a small cohort, applied to your real code.',
];

const faqItems = [
  {
    q: 'What if I can’t make every live session?',
    a: 'Sessions are recorded. Office hours offer makeup time. Total synchronous load is around <strong>6.5 hours over 5 weeks</strong>, designed to fit a working developer’s calendar.',
  },
  {
    q: 'What stack does this work with?',
    a: 'Tool-agnostic. Examples use <strong>Claude Code + HCF + Laravel</strong>, but the architecture transfers cleanly to any language and any AI coding tool. The principles are the durable thing; the tools are interchangeable.',
  },
  {
    q: 'How is this different from a YouTube AI coding tutorial?',
    a: 'Tutorials show one task. This builds the <em>system</em> around the tasks. You leave with a workflow architecture document for <em>your</em> codebase, not a recipe for one toy demo.',
  },
  {
    q: 'Who is this for?',
    a: 'Senior developers, tech leads, and solo product builders who already use AI to code daily and feel the chaos. Not for people who haven’t written code professionally. The assessment will tell you fast.',
  },
  {
    q: 'What’s the application process?',
    a: 'A short form: codebase context, your current AI workflow pain, and what you want to leave the cohort with. On approval, your card is authorized at the founding rate. The application is the filter, designed to keep the room small and serious.',
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title="AI Workflow Architecture · Cohort #1 · Mark Shust"
      description="A 5-week cohort for senior developers who want to design a workflow architecture for AI-assisted coding, applied to your real codebase. Limited to 10 seats. June 2026."
      image="/images/og-cohort.png"
    />
  </head>
  <body>
    <div class="site-wrapper">
      <Nav homepage={false} />

      <!-- ============ HERO ============ -->
      <section class="cohort-hero" id="join">
        <div class="blueprint-grid"></div>
        <div class="bg-text">/COHORT</div>
        <div class="hero-inner">
          <div class="hero-content reveal">
            <div class="hero-meta-row">
              <span class="hero-mono-label">01 / Cohort #1 · {cohortStartLabel}</span>
              <span class="seat-pill"><span class="seat-dot"></span>10 seats</span>
            </div>
            <h1 class="hero-title">
              is your AI coding workflow <span class="ht-grad">designed</span>, or improvised?
            </h1>
            <p class="hero-lead">
              Most AI-assisted coding is improvisation in disguise. <span class="hero-lead-l2"><strong>15 questions, 5 minutes</strong>, and you'll see exactly where the gaps are.</span>
            </p>

            <!-- 8-principle schematic -->
            <div class="schematic-grid" aria-hidden="true">
              {principles.map((p, i) => (
                <div class={`sg-cell sg-c${(i % 3) + 1}`}>
                  <div class="sg-num">{p.num}</div>
                  <div class="sg-name">{p.name}</div>
                </div>
              ))}
            </div>
            <p class="schematic-caption">
              The 8 architectural principles the assessment scores you against.
            </p>

            <!-- Primary CTA: take the assessment -->
            <div class="primary-cta-wrap">
              <a href="/cohort/ai-workflow/assessment" class="btn-primary">
                <span class="bp-prompt">&gt;</span>
                <span class="bp-text">take_the_assessment</span>
                <span class="bp-cursor">_</span>
              </a>
              <p class="primary-cta-fineprint">
                5 min · 15 questions · free
              </p>
              <p class="primary-cta-secondary">
                Score yours and lock in a founding-member offer for Cohort #1 (if you want it).
              </p>
            </div>

            <!-- Try one preview question -->
            <div class="try-one">
              <div class="try-one-label">
                <span class="t1l-prompt">&gt;</span> try one
              </div>
              <p class="try-one-q">
                Do you have an explicit planning phase that produces structured output (like a task list, spec, or plan file) <em>before</em> code generation begins?
              </p>
              <div class="try-one-choices">
                <a href="/cohort/ai-workflow/assessment?q1=yes#q01" class="t1-btn t1-yes">
                  <span class="t1b-key">Y</span>
                  <span class="t1b-text">YES</span>
                </a>
                <a href="/cohort/ai-workflow/assessment?q1=no#q01" class="t1-btn t1-no">
                  <span class="t1b-key">N</span>
                  <span class="t1b-text">NO</span>
                </a>
              </div>
              <p class="try-one-hint">
                Either answer drops you into the full assessment, with question 1 already filled in.
              </p>
            </div>

            <!-- Escape hatch: not ready for assessment, just join the waitlist -->
            <details class="escape-hatch">
              <summary class="eh-summary">
                <span class="eh-prompt">·</span>
                <span class="eh-text">Not ready to take the assessment? Just join the waitlist</span>
                <span class="eh-arrow">→</span>
              </summary>
              <div class="eh-form-wrap">
                <p class="eh-blurb">
                  Don't want to take the assessment? No problem. Just drop your email below, and I'll let you know when Cohort #1 registration opens.
                </p>
                <div class="kit-form-container kit-form-secondary">
                  <script async data-uid="4243ab2228" src="https://macademy.kit.com/4243ab2228/index.js" is:inline></script>
                </div>
                <p class="eh-fineprint">One email when registration opens. No spam.</p>
              </div>
            </details>
          </div>
        </div>
      </section>

      <DiagonalBand variant="1" />

      <!-- ============ OUTCOMES ============ -->
      <section class="cohort-outcomes" id="outcomes">
        <div class="bg-text bg-text-outcomes">SHIP</div>
        <div class="section-inner">
          <div class="reveal">
            <div class="section-label">02 / What you'll leave with</div>
            <h2 class="section-title">
              what you'll leave<br>
              cohort #1 <span class="highlight">with</span>.
            </h2>
          </div>

          <ul class="outcomes-list">
            {outcomes.map((o, i) => (
              <li class={`outcome-item reveal delay-${(i % 4) + 1}`}>
                <span class="oi-check" aria-hidden="true">
                  <span class="oi-check-mark"></span>
                </span>
                <span class="oi-text" set:html={o}></span>
              </li>
            ))}
          </ul>

          <!-- Pricing anchor -->
          <div class="pricing-strip reveal">
            <div class="ps-row">
              <div class="ps-item ps-primary">
                <div class="ps-label">Founding rate · Cohort #1</div>
                <div class="ps-price">
                  <span class="ps-currency">$</span><span class="ps-num">999</span>
                </div>
              </div>
              <div class="ps-divider" aria-hidden="true"></div>
              <div class="ps-item ps-secondary">
                <div class="ps-label">Cohort #2 onward</div>
                <div class="ps-price-future">$1,499 – $1,999</div>
              </div>
              <div class="ps-divider" aria-hidden="true"></div>
              <div class="ps-item ps-meta">
                <div class="ps-label">Seats</div>
                <div class="ps-meta-val">10 · application required</div>
              </div>
            </div>
            <p class="ps-note">
              Cohort #1 runs in <strong>{cohortStartLabel}</strong>. Exact dates announced to the waitlist first. Lock the founding rate by completing the assessment.
            </p>
          </div>
        </div>
      </section>

      <!-- ============ ABOUT / CREDIBILITY ============ -->
      <section class="cohort-about">
        <div class="bg-text bg-text-about">ARCHITECT</div>
        <div class="section-inner about-inner">
          <div class="about-portrait reveal-left">
            <div class="portrait-frame">
              <div class="portrait-grid"></div>
              <div class="portrait-scanline"></div>
              <div class="portrait-img"></div>
            </div>
            <div class="corner tl"></div>
            <div class="corner tr"></div>
            <div class="corner bl"></div>
            <div class="corner br"></div>
            <div class="float-tag">CLEVELAND, OH</div>
            <div class="float-code">
              <span class="fc-vr">$role</span> <span class="fc-punc">=</span> <span class="fc-str">'architect'</span><span class="fc-punc">;</span>
            </div>
          </div>

          <div class="about-content reveal-right">
            <div class="section-label">03 / Your guide</div>
            <h2 class="about-title">
              i use this workflow<br>
              <span class="highlight-orange">daily</span>.
            </h2>
            <p class="about-body">
              I'm Mark Shust, a developer and architect with 25+ years building production systems, founder of <a href="https://m.academy" target="_blank" rel="noreferrer">M.academy</a>, and creator of <a href="https://github.com/markshust/hcf" target="_blank" rel="noreferrer">HCF (Halt and Catch Fire)</a>, the Claude Code plugin that's the running case study throughout the cohort.
            </p>
            <p class="about-body">
              I use this workflow daily, in real OSS and client work. The cohort isn't theory. It's the system I've battle-tested, taught to teams, and now ship every product with.
            </p>

            <div class="about-stats">
              <div class="as-block">
                <div class="as-num">25<span class="as-plus">+</span></div>
                <div class="as-label">Years building</div>
              </div>
              <div class="as-block">
                <div class="as-num">15K<span class="as-plus">+</span></div>
                <div class="as-label">Students taught</div>
              </div>
              <div class="as-block">
                <div class="as-num">20<span class="as-plus">+</span></div>
                <div class="as-label">Courses shipped</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <DiagonalBand variant="2" />

      <!-- ============ FAQ ============ -->
      <FAQ items={faqItems} label="04 / FAQ" title="frequently" highlight="asked" />

      <!-- ============ FINAL CTA ============ -->
      <section class="cohort-final" id="join-bottom">
        <div class="bg-text bg-text-final">START</div>
        <div class="final-inner reveal">
          <div class="section-label">05 / Take the seat</div>
          <h2 class="final-title">
            still scrolling?<br>
            take the <span class="ht-grad">5-minute</span> assessment.
          </h2>
          <p class="final-body">
            It's free, ungated, and takes five minutes. See your score the moment you finish. If your result says you're a fit, you'll get a founding-member offer for Cohort #1.
          </p>
          <p class="final-body">
            Ten seats. June 2026.
          </p>
          <div class="final-cta-wrap">
            <a href="/cohort/ai-workflow/assessment" class="btn-primary btn-primary-final">
              <span class="bp-prompt">&gt;</span>
              <span class="bp-text">take_the_assessment</span>
              <span class="bp-cursor">_</span>
            </a>
            <p class="final-fineprint">
              cohort #1 · founding rate $999 · application after assessment
            </p>
          </div>
        </div>
      </section>

      <Footer />
    </div>

    <script>
      (function() {
        // Reveal-on-scroll
        const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -50px 0px' });
        els.forEach(el => obs.observe(el));

        // Smooth scroll for hash links
        document.querySelectorAll('a[href^="#"]').forEach(a => {
          a.addEventListener('click', (e) => {
            const href = a.getAttribute('href');
            if (!href || href === '#') return;
            const t = document.querySelector(href);
            if (t) {
              e.preventDefault();
              t.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          });
        });

        // Customize Kit form placeholder once Kit injects the form
        const setKitPlaceholder = () => {
          document.querySelectorAll('.kit-form-container .formkit-input').forEach(input => {
            if (input.placeholder !== 'Email address') {
              input.placeholder = 'Email address';
              input.setAttribute('aria-label', 'Email address');
            }
          });
        };
        document.querySelectorAll('.kit-form-container').forEach(container => {
          new MutationObserver(setKitPlaceholder).observe(container, { childList: true, subtree: true });
        });
        setKitPlaceholder();
      })();
    </script>

    <style>
      .site-wrapper {
        max-width: 2560px;
        margin: 0 auto;
        background: var(--dark);
        position: relative;
        overflow-x: hidden;
      }

      /* ============ Shared ============ */
      .section-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }
      .section-label {
        font-family: var(--font-mono);
        font-size: clamp(0.8rem, 1vw, 0.9rem);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin-bottom: 0.75rem;
        opacity: 0.6;
        color: var(--gray-light);
      }
      .section-title {
        font-family: var(--font-heading);
        font-size: clamp(3rem, 6vw, 5rem);
        font-weight: 700;
        line-height: 0.95;
        letter-spacing: -0.04em;
        margin-bottom: 3rem;
        color: var(--white);
      }
      .section-title .highlight {
        background: linear-gradient(90deg, var(--orange), var(--green));
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .ht-grad {
        background: linear-gradient(90deg, var(--orange), var(--blue) 50%, var(--green));
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .highlight-orange { color: var(--orange); }
      .bg-text {
        position: absolute;
        font-family: var(--font-heading);
        font-weight: 700;
        line-height: 0.85;
        pointer-events: none;
        letter-spacing: -0.05em;
        color: rgba(255,255,255,0.025);
        font-size: clamp(8rem, 18vw, 20rem);
      }

      /* ============ HERO ============ */
      .cohort-hero {
        position: relative;
        padding: 9rem 2.5rem clamp(7rem, 12vw, 10rem);
        background: var(--dark);
        overflow: hidden;
        min-height: 95vh;
        display: flex;
        align-items: center;
      }
      .blueprint-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        mask-image: radial-gradient(circle at 50% 30%, #000 30%, transparent 80%);
        -webkit-mask-image: radial-gradient(circle at 50% 30%, #000 30%, transparent 80%);
      }
      .cohort-hero::before {
        content: '';
        position: absolute;
        top: -10%; left: -10%;
        width: 50%; height: 60%;
        background: radial-gradient(circle, rgba(255,107,53,0.10), transparent 65%);
        pointer-events: none;
      }
      .cohort-hero::after {
        content: '';
        position: absolute;
        bottom: -10%; right: -10%;
        width: 50%; height: 60%;
        background: radial-gradient(circle, rgba(16,185,129,0.10), transparent 65%);
        pointer-events: none;
      }
      .cohort-hero .bg-text {
        top: 7rem; right: -1rem;
      }
      .hero-inner {
        max-width: 980px;
        margin: 0 auto;
        width: 100%;
        position: relative;
        z-index: 1;
      }
      .hero-meta-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
      }
      .hero-mono-label {
        font-family: var(--font-mono);
        font-size: clamp(0.78rem, 0.95vw, 0.9rem);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--gray-light);
        opacity: 0.8;
      }
      .seat-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        padding: 0.35rem 0.75rem;
        background: rgba(16,185,129,0.12);
        border: 1px solid rgba(16,185,129,0.3);
        border-radius: 100px;
        color: var(--green-bright);
      }
      .seat-dot {
        width: 7px; height: 7px;
        background: var(--green);
        border-radius: 50%;
        box-shadow: 0 0 0 3px rgba(16,185,129,0.25);
        animation: pulseDot 2s ease-in-out infinite;
      }
      @keyframes pulseDot {
        0%, 100% { box-shadow: 0 0 0 3px rgba(16,185,129,0.25); }
        50% { box-shadow: 0 0 0 7px rgba(16,185,129,0.05); }
      }
      .hero-title {
        font-family: var(--font-heading);
        font-size: clamp(2.75rem, 6.5vw, 5.25rem);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
        color: var(--white);
        max-width: 800px;
      }
      .hero-lead {
        font-size: clamp(1.1rem, 1.4vw, 1.3rem);
        line-height: 1.6;
        color: var(--gray-light);
        max-width: 740px;
        margin-bottom: 2rem;
      }
      .hero-lead strong { color: var(--white); }
      .hero-lead em { color: var(--orange-bright); font-style: italic; }
      @media (min-width: 769px) {
        .hero-lead-l2 { display: block; margin-top: 0.4rem; }
      }

      /* 8-principle schematic */
      .schematic-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.6rem;
        margin-bottom: 0.65rem;
        padding: 1.25rem;
        background: rgba(20,20,28,0.6);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 14px;
      }
      .sg-cell {
        padding: 0.85rem 0.95rem;
        border-radius: 8px;
        position: relative;
      }
      .sg-num {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        opacity: 0.7;
        margin-bottom: 0.25rem;
      }
      .sg-name {
        font-family: var(--font-heading);
        font-size: clamp(0.85rem, 1.1vw, 1rem);
        font-weight: 700;
        letter-spacing: -0.01em;
        line-height: 1.15;
      }
      .sg-c1 { background: rgba(255,107,53,0.10); border: 1px solid rgba(255,107,53,0.30); color: var(--orange-bright); }
      .sg-c2 { background: rgba(59,130,246,0.10); border: 1px solid rgba(59,130,246,0.30); color: var(--blue-bright); }
      .sg-c3 { background: rgba(16,185,129,0.10); border: 1px solid rgba(16,185,129,0.30); color: var(--green-bright); }
      .schematic-caption {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--gray);
        opacity: 0.7;
        margin-bottom: 2.25rem;
        letter-spacing: 0.04em;
      }

      /* Primary CTA */
      .primary-cta-wrap {
        margin-bottom: 2rem;
        text-align: center;
      }
      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--font-mono);
        font-size: clamp(0.95rem, 1.15vw, 1.1rem);
        font-weight: 700;
        text-transform: lowercase;
        letter-spacing: 0.04em;
        color: #000;
        background: linear-gradient(90deg, var(--orange), var(--green));
        padding: 1.05rem 1.75rem;
        border-radius: 100px;
        text-decoration: none;
        position: relative;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        box-shadow: 0 12px 36px rgba(255,107,53,0.28);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 48px rgba(255,107,53,0.38);
      }
      .bp-prompt { font-weight: 700; }
      .bp-cursor {
        animation: blink 1.1s step-end infinite;
        margin-left: 0.1rem;
      }
      @keyframes blink { 50% { opacity: 0; } }
      .primary-cta-fineprint {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--gray);
        margin-top: 0.85rem;
        letter-spacing: 0.04em;
      }
      .primary-cta-secondary {
        font-size: 0.95rem;
        color: var(--gray-light);
        margin: 0.4rem auto 0;
        line-height: 1.55;
        max-width: 660px;
      }

      /* Try one preview */
      .try-one {
        margin: 4.5rem auto 0;
        background: var(--dark-card);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: clamp(1.2rem, 2vw, 1.6rem);
        max-width: 760px;
        position: relative;
        text-align: left;
      }
      .try-one::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        height: 3px;
        width: 100%;
        background: linear-gradient(90deg, var(--orange), var(--blue) 50%, var(--green));
        border-radius: 14px 14px 0 0;
      }
      .try-one-label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gray);
        margin-bottom: 0.65rem;
      }
      .t1l-prompt { color: var(--orange); margin-right: 0.4rem; }
      .try-one-q {
        font-size: clamp(0.98rem, 1.15vw, 1.08rem);
        line-height: 1.55;
        color: var(--white);
        margin-bottom: 1rem;
      }
      .try-one-q em { color: var(--orange-bright); font-style: italic; font-weight: 500; }
      .try-one-choices {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
      }
      .t1-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-family: var(--font-heading);
        font-size: clamp(0.9rem, 1.05vw, 1rem);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.85rem 1rem;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.03);
        color: var(--gray-light);
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
      }
      .t1-btn:hover { transform: translateY(-1px); }
      .t1b-key {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 700;
        width: 18px; height: 18px;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 4px;
        opacity: 0.7;
      }
      .t1-yes:hover {
        background: rgba(16,185,129,0.10);
        border-color: rgba(16,185,129,0.45);
        color: var(--green-bright);
      }
      .t1-no:hover {
        background: rgba(255,107,53,0.08);
        border-color: rgba(255,107,53,0.4);
        color: var(--orange-bright);
      }
      .try-one-hint {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--gray);
        opacity: 0.65;
        margin-top: 0.85rem;
        letter-spacing: 0.04em;
      }

      /* Escape hatch */
      .escape-hatch {
        margin: 2rem auto 0;
        max-width: 620px;
        text-align: center;
      }
      .escape-hatch[open] .eh-form-wrap { text-align: left; }
      .eh-summary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--gray);
        cursor: pointer;
        list-style: none;
        padding: 0.55rem 0;
        transition: color 0.2s ease;
      }
      .eh-summary::-webkit-details-marker { display: none; }
      .eh-summary:hover { color: var(--gray-light); }
      .eh-prompt { color: var(--orange); margin-right: 0.1rem; }
      .eh-text {
        border-bottom: 1px dashed rgba(255,255,255,0.18);
      }
      .eh-arrow {
        transition: transform 0.25s ease;
      }
      .escape-hatch[open] .eh-arrow { transform: rotate(90deg); }
      .eh-form-wrap {
        margin-top: 0.85rem;
        padding: 1rem 1.1rem;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
      }
      .eh-blurb {
        font-size: 0.92rem;
        color: var(--gray-light);
        line-height: 1.55;
        margin-bottom: 0.85rem;
      }
      .eh-fineprint {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--gray);
        opacity: 0.6;
        margin-top: 0.5rem;
        letter-spacing: 0.04em;
      }

      /* Kit form styling (shared) */
      .kit-form-container :global(form) {
        background: transparent !important;
        padding: 0 !important;
        border: 0 !important;
        max-width: none !important;
      }
      .kit-form-container :global(form > div) {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
      }
      .kit-form-container :global(.formkit-input) {
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.12) !important;
        color: var(--white) !important;
        font-family: var(--font-mono) !important;
        border-radius: 8px !important;
      }
      .kit-form-container :global(.formkit-input::placeholder) {
        color: var(--gray) !important;
        opacity: 0.45 !important;
        font-family: var(--font-mono) !important;
      }
      .kit-form-container :global(.formkit-input::-webkit-input-placeholder) {
        color: var(--gray) !important;
        opacity: 0.45 !important;
      }
      .kit-form-container :global(.formkit-input::-moz-placeholder) {
        color: var(--gray) !important;
        opacity: 0.45 !important;
      }
      .kit-form-container :global(button[type="submit"]) {
        background: linear-gradient(90deg, var(--orange), var(--green)) !important;
        color: #000 !important;
        font-family: var(--font-heading) !important;
        font-weight: 700 !important;
        border-radius: 100px !important;
        border: 0 !important;
      }

      /* ============ OUTCOMES ============ */
      .cohort-outcomes {
        background: var(--dark-card);
        padding: clamp(13rem, 19vw, 18rem) 2.5rem clamp(4rem, 7vw, 6rem);
        position: relative;
        overflow: hidden;
      }
      .bg-text-outcomes { top: 5.5rem; left: -0.5rem; }
      .outcomes-list {
        list-style: none;
        padding: 0;
        margin: 0 0 3rem 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem 2.5rem;
      }
      .outcome-item {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        padding: 1rem 1.1rem;
        background: var(--dark);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        transition: border-color 0.3s ease, transform 0.3s ease;
      }
      .outcome-item:hover {
        border-color: rgba(16,185,129,0.35);
        transform: translateY(-2px);
      }
      .oi-check {
        flex-shrink: 0;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: rgba(16,185,129,0.14);
        border: 1px solid rgba(16,185,129,0.4);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-top: 0.15rem;
      }
      .oi-check-mark {
        width: 10px;
        height: 6px;
        border-left: 2px solid var(--green-bright);
        border-bottom: 2px solid var(--green-bright);
        transform: rotate(-45deg) translate(1px, -1px);
      }
      .oi-text {
        font-size: clamp(0.95rem, 1.1vw, 1.02rem);
        line-height: 1.55;
        color: var(--gray-light);
      }
      .oi-text em {
        color: var(--white);
        font-style: italic;
        font-weight: 500;
      }

      /* Pricing strip */
      .pricing-strip {
        background: var(--dark);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: clamp(1.5rem, 2.5vw, 2rem);
        position: relative;
        overflow: hidden;
      }
      .pricing-strip::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--orange), var(--blue), var(--green));
        border-radius: 16px 16px 0 0;
      }
      .ps-row {
        display: grid;
        grid-template-columns: auto 1px 1fr 1px 1fr;
        gap: 1.5rem;
        align-items: center;
      }
      .ps-divider {
        width: 1px;
        height: 56px;
        background: rgba(255,255,255,0.08);
      }
      .ps-item {
        text-align: left;
      }
      .ps-label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--gray);
        margin-bottom: 0.4rem;
      }
      .ps-price {
        font-family: var(--font-heading);
        font-weight: 700;
        line-height: 1;
        color: var(--white);
        display: inline-flex;
        align-items: baseline;
      }
      .ps-currency {
        font-size: clamp(1.2rem, 1.8vw, 1.5rem);
        color: var(--orange-bright);
        margin-right: 0.15rem;
      }
      .ps-num {
        font-size: clamp(2.5rem, 4.5vw, 3.5rem);
        background: linear-gradient(90deg, var(--orange), var(--green));
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.04em;
      }
      .ps-price-future {
        font-family: var(--font-heading);
        font-size: clamp(1.05rem, 1.4vw, 1.25rem);
        font-weight: 700;
        color: var(--gray-light);
        opacity: 0.85;
      }
      .ps-meta-val {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--white);
        letter-spacing: 0.02em;
      }
      .ps-note {
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 1px dashed rgba(255,255,255,0.08);
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--gray-light);
        line-height: 1.65;
        opacity: 0.85;
      }
      .ps-note strong { color: var(--orange-bright); font-weight: 700; }

      /* ============ ABOUT ============ */
      .cohort-about {
        background: var(--dark);
        padding: clamp(4rem, 7vw, 6rem) 2.5rem clamp(11rem, 18vw, 16rem);
        position: relative;
        overflow: hidden;
      }
      .bg-text-about { top: -1rem; right: -1rem; }
      .about-inner {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 4rem;
        align-items: center;
      }
      .about-portrait {
        position: relative;
        max-width: 400px;
        margin: 0 auto;
        width: 100%;
        aspect-ratio: 4/5;
      }
      .portrait-frame {
        width: 100%;
        height: 100%;
        background: var(--dark-card) url('/images/mark-shust-bg.jpg') center/cover no-repeat;
        position: relative;
        overflow: hidden;
        clip-path: polygon(
          0% 5%, 5% 5%, 5% 0%,
          68% 0%, 68% 2.5%, 95% 2.5%, 95% 0%, 100% 0%,
          100% 62%, 97.5% 62%, 97.5% 68%, 100% 68%,
          100% 95%, 95% 95%, 95% 100%,
          32% 100%, 32% 97.5%, 5% 97.5%, 5% 100%, 0% 100%,
          0% 68%, 2.5% 68%, 2.5% 62%, 0% 62%
        );
      }
      .portrait-frame::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,107,53,0.12) 0%, rgba(59,130,246,0.08) 50%, rgba(16,185,129,0.12) 100%);
        z-index: 5;
        pointer-events: none;
      }
      .portrait-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 24px 24px;
        z-index: 1;
      }
      .portrait-scanline {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,107,53,0.3), rgba(59,130,246,0.3), rgba(16,185,129,0.3), transparent);
        z-index: 2;
        animation: scanDown 14s linear infinite;
      }
      .portrait-img {
        position: absolute;
        inset: 0;
        background: url('/images/mark-shust-over.png') center/cover no-repeat;
        z-index: 3;
        pointer-events: none;
      }
      @keyframes scanDown {
        0% { top: -1px; opacity: 0.2; }
        15% { opacity: 0.6; }
        50% { opacity: 0.4; }
        100% { top: 100%; opacity: 0.2; }
      }
      .corner { position: absolute; width: 22px; height: 22px; z-index: 4; }
      .corner::before, .corner::after { content: ''; position: absolute; }
      .corner.tl { top: -8px; left: -8px; }
      .corner.tl::before { width: 22px; height: 3px; top: 0; left: 0; background: var(--orange); }
      .corner.tl::after { width: 3px; height: 22px; top: 0; left: 0; background: var(--orange); }
      .corner.tr { top: -8px; right: -8px; }
      .corner.tr::before { width: 22px; height: 3px; top: 0; right: 0; background: var(--blue); }
      .corner.tr::after { width: 3px; height: 22px; top: 0; right: 0; background: var(--blue); }
      .corner.bl { bottom: -8px; left: -8px; }
      .corner.bl::before { width: 22px; height: 3px; bottom: 0; left: 0; background: var(--green); }
      .corner.bl::after { width: 3px; height: 22px; bottom: 0; left: 0; background: var(--green); }
      .corner.br { bottom: -8px; right: -8px; }
      .corner.br::before { width: 22px; height: 3px; bottom: 0; right: 0; background: #444; }
      .corner.br::after { width: 3px; height: 22px; bottom: 0; right: 0; background: #444; }

      .float-tag {
        position: absolute;
        top: -16px; left: -25px;
        background: var(--orange);
        color: #000;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 0.45rem 0.9rem;
        border-radius: 6px;
        z-index: 6;
        box-shadow: 0 10px 35px rgba(255,107,53,0.35);
        animation: floatLabel 6s ease-in-out infinite;
      }
      @keyframes floatLabel {
        0%, 100% { transform: translateY(0) rotate(-2deg); }
        50% { transform: translateY(-6px) rotate(1deg); }
      }
      .float-code {
        position: absolute;
        bottom: -22px; right: -25px;
        background: rgba(20,20,28,0.92);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.85rem 1.2rem;
        border-radius: 10px;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        z-index: 6;
        box-shadow: 0 16px 50px rgba(0,0,0,0.6);
        animation: floatBadge 5s ease-in-out infinite;
      }
      @keyframes floatBadge {
        0%, 100% { transform: translateY(0) rotate(1deg); }
        50% { transform: translateY(-8px) rotate(-1deg); }
      }
      .fc-vr { color: var(--orange-bright); }
      .fc-str { color: var(--green-bright); }
      .fc-punc { color: var(--gray); }

      .about-title {
        font-family: var(--font-heading);
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        line-height: 0.98;
        letter-spacing: -0.04em;
        margin-bottom: 1.75rem;
        color: var(--white);
      }
      .about-body {
        font-size: clamp(1rem, 1.2vw, 1.1rem);
        line-height: 1.75;
        color: var(--gray-light);
        margin-bottom: 1.25rem;
        max-width: 600px;
      }
      .about-body a {
        color: var(--orange);
        text-decoration: none;
        border-bottom: 1px dashed rgba(255,107,53,0.5);
      }
      .about-body a:hover {
        color: var(--orange-bright);
        border-bottom-color: var(--orange-bright);
      }
      .about-stats {
        display: flex;
        gap: 2.5rem;
        margin-top: 2rem;
        flex-wrap: wrap;
      }
      .as-block { text-align: left; }
      .as-num {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 3vw, 2.5rem);
        font-weight: 700;
        color: var(--white);
        line-height: 1;
      }
      .as-plus { color: var(--orange); }
      .as-label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--gray);
        margin-top: 0.4rem;
      }

      /* ============ FINAL CTA ============ */
      .cohort-final {
        background: var(--dark-card);
        padding: clamp(13rem, 19vw, 18rem) 2.5rem clamp(7rem, 12vw, 10rem);
        position: relative;
        overflow: hidden;
        text-align: center;
      }
      .bg-text-final { top: 6rem; left: 50%; transform: translateX(-50%); white-space: nowrap; }
      .final-inner {
        max-width: 720px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }
      .cohort-final .section-label {
        text-align: center;
      }
      .final-title {
        font-family: var(--font-heading);
        font-size: clamp(2.75rem, 5.5vw, 4.5rem);
        font-weight: 700;
        line-height: 0.98;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
        color: var(--white);
      }
      .final-body {
        font-size: clamp(1.05rem, 1.3vw, 1.2rem);
        line-height: 1.7;
        color: var(--gray-light);
        margin: 0 auto 1.25rem;
        max-width: 33rem;
        text-align: left;
      }
      .final-body + .final-body { margin-bottom: 2.5rem; }
      .final-cta-wrap { margin-top: 1rem; }
      .btn-primary-final {
        font-size: clamp(1rem, 1.2vw, 1.15rem);
        padding: 1.1rem 1.85rem;
      }
      .final-fineprint {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--gray);
        margin-top: 1rem;
        letter-spacing: 0.04em;
        opacity: 0.7;
      }

      /* ============ Responsive ============ */
      @media (max-width: 1024px) {
        .schematic-grid { grid-template-columns: repeat(4, 1fr); }
        .outcomes-list { grid-template-columns: 1fr; }
        .ps-row { grid-template-columns: 1fr; gap: 1rem; }
        .ps-divider { display: none; }
        .about-inner { grid-template-columns: 1fr; gap: 5rem; }
        .about-portrait { max-width: 340px; }
        .about-stats { justify-content: flex-start; }
      }
      @media (max-width: 768px) {
        .cohort-hero { padding: 4.5rem 1.25rem 4rem; min-height: auto; }
        .cohort-outcomes, .cohort-about, .cohort-final { padding: 6rem 1.25rem; }
        .hero-lead { margin-bottom: 1.25rem; }
        .schematic-grid {
          grid-template-columns: repeat(4, 1fr);
          padding: 0.75rem;
          gap: 0.4rem;
          margin-bottom: 0.5rem;
        }
        .sg-cell { padding: 0.55rem 0.55rem; }
        .sg-num { font-size: 0.55rem; margin-bottom: 0.15rem; }
        .sg-name { font-size: 0.78rem; }
        .schematic-caption { margin-bottom: 1.5rem; font-size: 0.7rem; }
        .float-tag, .float-code { display: none; }
        .try-one { padding: 1.1rem; margin-top: 3.25rem; }
        .escape-hatch { margin-top: 1.5rem; }
      }
      @media (max-width: 480px) {
        .hero-title { font-size: clamp(2rem, 8.5vw, 2.5rem); margin-bottom: 0.85rem; }
        .hero-meta-row { margin-bottom: 1rem; }
        .hero-lead { font-size: 0.98rem; margin-bottom: 0.85rem; }
        .schematic-grid {
          grid-template-columns: repeat(4, 1fr);
          gap: 0.3rem;
          padding: 0.55rem;
          margin-bottom: 0.4rem;
        }
        .sg-cell { padding: 0.45rem 0.45rem; }
        .sg-num { font-size: 0.5rem; margin-bottom: 0.1rem; }
        .sg-name { font-size: 0.66rem; line-height: 1.1; }
        .schematic-caption { margin-bottom: 1.1rem; font-size: 0.65rem; }
        .try-one-choices { gap: 0.5rem; }
        .ps-num { font-size: clamp(2.25rem, 12vw, 3rem); }
        .btn-primary { font-size: 0.95rem; padding: 0.9rem 1.35rem; }
        .primary-cta-fineprint { font-size: 0.72rem; margin-top: 0.7rem; }
        .primary-cta-secondary { font-size: 0.88rem; }
      }
    </style>
  </body>
</html>
