---
import BaseHead from '../../components/BaseHead.astro';
import Nav from '../../components/Nav.astro';
import DiagonalBand from '../../components/DiagonalBand.astro';
import Footer from '../../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title="AI Workflow Architecture · Cohort #1 · Mark Shust"
      description="A 5-week cohort for senior developers who want to design a workflow architecture for AI-assisted coding, applied to your real codebase. Limited to 10 seats. June 2026."
      image="/images/og-cohort.png"
    />
  </head>
  <body>
    <div class="site-wrapper">
      <Nav homepage={false} />

      <!-- ============ HERO ============ -->
      <section class="cohort-hero" id="join">
        <div class="blueprint-grid"></div>
        <div class="bg-text">/COHORT</div>
        <div class="hero-inner">
          <div class="hero-content reveal">
            <div class="hero-meta-row">
              <span class="hero-mono-label">01 / Cohort #1 · June 2026</span>
              <span class="seat-pill"><span class="seat-dot"></span>10 seats</span>
            </div>
            <h1 class="hero-title">
              Stop Prompting.<br>
              Start <span class="ht-grad">Architecting</span>.
            </h1>
            <p class="hero-lead">
              Most AI-assisted coding is still improvisation. Scattered prompts, lost context, code you don't quite trust.
            </p>
            <p class="hero-lead">
              The fix isn't better prompts, but <strong>workflow architecture</strong>: defined stages, explicit handoffs, and bounded responsibility for the AI.
            </p>
            <!-- Architecture schematic -->
            <div class="schematic" aria-hidden="true">
              <div class="stage stage-orange">
                <div class="stage-num">01</div>
                <div class="stage-name">Stages</div>
              </div>
              <div class="link-arrow"></div>
              <div class="stage stage-blue">
                <div class="stage-num">02</div>
                <div class="stage-name">Handoffs</div>
              </div>
              <div class="link-arrow"></div>
              <div class="stage stage-green">
                <div class="stage-num">03</div>
                <div class="stage-name">Bounded</div>
              </div>
            </div>

            <p class="hero-lead">
              I'm running a <strong>5-week cohort</strong> for senior developers who want to design that system from the ground up, applied to your real codebase, not a toy demo.
            </p>

            <div class="form-wrap">
              <div class="form-label">
                <span class="prompt">&gt;</span> Reserve your seat
                <span class="cursor">_</span>
              </div>
              <div class="kit-form-container">
                <script async data-uid="502388255d" src="https://macademy.kit.com/502388255d/index.js" is:inline></script>
              </div>
              <p class="form-fineprint">
                Lock in founding-member pricing.
              </p>
              <p class="form-fineprint">
                Free <strong>AI Workflow Architecture Self-Assessment</strong> when you join.
              </p>
            </div>
            <p class="form-trust-note">
              One email when registration opens. No spam.
            </p>
          </div>
        </div>
      </section>

      <DiagonalBand variant="1" />

      <!-- ============ BENEFITS ============ -->
      <section class="cohort-benefits" id="benefits">
        <div class="bg-text bg-text-benefits">WAITLIST</div>
        <div class="section-inner">
          <div class="reveal">
            <div class="section-label">02 / What you get</div>
            <h2 class="section-title">three reasons<br>to join <span class="highlight">today</span>.</h2>
          </div>

          <div class="benefits-grid">
            <article class="benefit-card bc-orange reveal delay-1">
              <div class="bc-num">01</div>
              <h3 class="bc-title">First access</h3>
              <p class="bc-body">When public registration opens, you're at the front of the line. Cohort #1 is capped at 10 seats, and they'll move fast.</p>
              <div class="bc-tag">PRIORITY ENROLLMENT</div>
            </article>

            <article class="benefit-card bc-blue reveal delay-2">
              <div class="bc-num">02</div>
              <h3 class="bc-title">Founding pricing</h3>
              <p class="bc-body">A locked-in lower rate than future cohorts will pay. Founding members ship the playbook with me, and your tuition reflects that.</p>
              <div class="bc-tag">LIFETIME RATE</div>
            </article>

            <article class="benefit-card bc-green reveal delay-3">
              <div class="bc-num">03</div>
              <h3 class="bc-title">Free self-assessment</h3>
              <p class="bc-body">Get a link when you join to score your current workflow against the 8 architectural principles and see exactly where the gaps are.</p>
              <div class="principle-grid" aria-hidden="true">
                <span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span>
              </div>
              <div class="bc-tag">8 PRINCIPLES</div>
            </article>
          </div>

          <p class="benefits-fine reveal delay-4">
            <span class="bf-icon">⌘</span>
            Bringing your team? Team rates are available. Reply to your waitlist confirmation for details.
          </p>
        </div>
      </section>

      <!-- ============ ABOUT / CREDIBILITY ============ -->
      <section class="cohort-about">
        <div class="bg-text bg-text-about">ARCHITECT</div>
        <div class="section-inner about-inner">
          <div class="about-portrait reveal-left">
            <div class="portrait-frame">
              <div class="portrait-grid"></div>
              <div class="portrait-scanline"></div>
              <div class="portrait-img"></div>
            </div>
            <div class="corner tl"></div>
            <div class="corner tr"></div>
            <div class="corner bl"></div>
            <div class="corner br"></div>
            <div class="float-tag">CLEVELAND, OH</div>
            <div class="float-code">
              <span class="fc-vr">$role</span> <span class="fc-punc">=</span> <span class="fc-str">'architect'</span><span class="fc-punc">;</span>
            </div>
          </div>

          <div class="about-content reveal-right">
            <div class="section-label">03 / Your guide</div>
            <h2 class="about-title">
              I use this workflow<br>
              <span class="highlight-orange">daily</span>.
            </h2>
            <p class="about-body">
              I'm Mark Shust, a developer and architect with 25+ years building production systems, founder of <a href="https://m.academy" target="_blank" rel="noreferrer">M.academy</a>, and creator of <a href="https://github.com/markshust/hcf" target="_blank" rel="noreferrer">HCF (Halt and Catch Fire)</a>, the Claude Code plugin that's the running case study throughout the cohort.
            </p>
            <p class="about-body">
              I use this workflow daily, in real OSS and client work. The cohort isn't theory. It's the system I've battle-tested, taught to teams, and now ship every product with.
            </p>

            <div class="about-stats">
              <div class="as-block">
                <div class="as-num">25<span class="as-plus">+</span></div>
                <div class="as-label">Years building</div>
              </div>
              <div class="as-block">
                <div class="as-num">15K<span class="as-plus">+</span></div>
                <div class="as-label">Students taught</div>
              </div>
              <div class="as-block">
                <div class="as-num">20<span class="as-plus">+</span></div>
                <div class="as-label">Courses shipped</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <DiagonalBand variant="2" />

      <!-- ============ FINAL CTA ============ -->
      <section class="cohort-final" id="join-bottom">
        <div class="bg-text bg-text-final">JOIN</div>
        <div class="final-inner reveal">
          <div class="section-label">04 / Take the seat</div>
          <h2 class="final-title">
            Ten seats.<br>
            One <span class="ht-grad">cohort</span>.
          </h2>
          <p class="final-body">
            Most cohorts overpromise. This one is small on purpose: 10 seats, 5 weeks, applied to <em>your</em> codebase.
          </p>
          <p class="final-body">
            Get on the list, lock in founding pricing, and grab the self‑assessment while you're at it.
          </p>
          <div class="form-wrap">
            <div class="form-label">
              <span class="prompt">&gt;</span> Reserve your seat
              <span class="cursor">_</span>
            </div>
            <div class="kit-form-container">
              <script async data-uid="502388255d" src="https://macademy.kit.com/502388255d/index.js" is:inline></script>
            </div>
            <p class="form-fineprint">
              Lock in founding-member pricing.
            </p>
            <p class="form-fineprint">
              Free <strong>AI Workflow Architecture Self-Assessment</strong> when you join.
            </p>
          </div>
          <p class="form-trust-note">
            One email when registration opens. No spam.
          </p>
        </div>
      </section>

      <Footer />
    </div>

    <script>
      (function() {
        // Reveal-on-scroll
        const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -50px 0px' });
        els.forEach(el => obs.observe(el));

        // Smooth scroll for hash links
        document.querySelectorAll('a[href^="#"]').forEach(a => {
          a.addEventListener('click', (e) => {
            const href = a.getAttribute('href');
            if (!href || href === '#') return;
            const t = document.querySelector(href);
            if (t) {
              e.preventDefault();
              t.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          });
        });

        // Customize Kit form placeholder once Kit injects the form
        const setKitPlaceholder = () => {
          document.querySelectorAll('.kit-form-container .formkit-input').forEach(input => {
            if (input.placeholder !== 'Email address') {
              input.placeholder = 'Email address';
              input.setAttribute('aria-label', 'Email address');
            }
          });
        };
        document.querySelectorAll('.kit-form-container').forEach(container => {
          new MutationObserver(setKitPlaceholder).observe(container, { childList: true, subtree: true });
        });
        setKitPlaceholder();
      })();
    </script>

    <style>
      .site-wrapper {
        max-width: 2560px;
        margin: 0 auto;
        background: var(--dark);
        position: relative;
        overflow-x: hidden;
      }

      /* ============ Shared ============ */
      .section-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }
      .section-label {
        font-family: var(--font-mono);
        font-size: clamp(0.8rem, 1vw, 0.9rem);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin-bottom: 0.75rem;
        opacity: 0.6;
        color: var(--gray-light);
      }
      .section-title {
        font-family: var(--font-heading);
        font-size: clamp(3rem, 6vw, 5rem);
        font-weight: 700;
        line-height: 0.95;
        letter-spacing: -0.04em;
        margin-bottom: 3rem;
        color: var(--white);
      }
      .section-title .highlight {
        background: linear-gradient(90deg, var(--orange), var(--green));
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .ht-grad {
        background: linear-gradient(90deg, var(--orange), var(--blue) 50%, var(--green));
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .highlight-orange { color: var(--orange); }
      .bg-text {
        position: absolute;
        font-family: var(--font-heading);
        font-weight: 700;
        line-height: 0.85;
        pointer-events: none;
        letter-spacing: -0.05em;
        color: rgba(255,255,255,0.025);
        font-size: clamp(8rem, 18vw, 20rem);
      }

      /* ============ HERO ============ */
      .cohort-hero {
        position: relative;
        padding: 9rem 2.5rem clamp(7rem, 12vw, 10rem);
        background: var(--dark);
        overflow: hidden;
        min-height: 95vh;
        display: flex;
        align-items: center;
      }
      .blueprint-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        mask-image: radial-gradient(circle at 50% 30%, #000 30%, transparent 80%);
        -webkit-mask-image: radial-gradient(circle at 50% 30%, #000 30%, transparent 80%);
      }
      .cohort-hero::before {
        content: '';
        position: absolute;
        top: -10%; left: -10%;
        width: 50%; height: 60%;
        background: radial-gradient(circle, rgba(255,107,53,0.10), transparent 65%);
        pointer-events: none;
      }
      .cohort-hero::after {
        content: '';
        position: absolute;
        bottom: -10%; right: -10%;
        width: 50%; height: 60%;
        background: radial-gradient(circle, rgba(16,185,129,0.10), transparent 65%);
        pointer-events: none;
      }
      .cohort-hero .bg-text {
        top: 7rem; right: -1rem;
      }
      .hero-inner {
        max-width: 980px;
        margin: 0 auto;
        width: 100%;
        position: relative;
        z-index: 1;
      }
      .hero-meta-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
      }
      .hero-mono-label {
        font-family: var(--font-mono);
        font-size: clamp(0.78rem, 0.95vw, 0.9rem);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--gray-light);
        opacity: 0.8;
      }
      .seat-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        padding: 0.35rem 0.75rem;
        background: rgba(16,185,129,0.12);
        border: 1px solid rgba(16,185,129,0.3);
        border-radius: 100px;
        color: var(--green-bright);
      }
      .seat-dot {
        width: 7px; height: 7px;
        background: var(--green);
        border-radius: 50%;
        box-shadow: 0 0 0 3px rgba(16,185,129,0.25);
        animation: pulseDot 2s ease-in-out infinite;
      }
      @keyframes pulseDot {
        0%, 100% { box-shadow: 0 0 0 3px rgba(16,185,129,0.25); }
        50% { box-shadow: 0 0 0 7px rgba(16,185,129,0.05); }
      }
      .hero-title {
        font-family: var(--font-heading);
        font-size: clamp(3rem, 7vw, 6rem);
        font-weight: 700;
        line-height: 0.95;
        letter-spacing: -0.04em;
        margin-bottom: 1.75rem;
        color: var(--white);
      }
      .hero-lead {
        font-size: clamp(1.1rem, 1.4vw, 1.3rem);
        line-height: 1.7;
        color: var(--gray-light);
        max-width: 740px;
        margin-bottom: 1.25rem;
      }
      .hero-lead strong { color: var(--white); }
      .schematic + .hero-lead { margin-bottom: 2.75rem; }
      .hero-lead-sub {
        font-size: clamp(1rem, 1.2vw, 1.15rem);
        line-height: 1.7;
        color: var(--gray);
        max-width: 740px;
        margin-bottom: 2.5rem;
      }
      .hero-lead-sub strong { color: var(--white); }

      /* Schematic */
      .schematic {
        display: flex;
        align-items: stretch;
        gap: 0;
        margin-bottom: 1.5rem;
        padding: 1.5rem;
        background: rgba(20,20,28,0.6);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 14px;
        overflow-x: auto;
      }
      .stage {
        flex: 1;
        min-width: 110px;
        padding: 1.1rem 1.25rem;
        border-radius: 10px;
        position: relative;
      }
      .stage-num {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        opacity: 0.7;
        margin-bottom: 0.4rem;
      }
      .stage-name {
        font-family: var(--font-heading);
        font-size: clamp(1.05rem, 1.5vw, 1.35rem);
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      .stage-orange { background: rgba(255,107,53,0.12); border: 1px solid rgba(255,107,53,0.35); color: var(--orange-bright); }
      .stage-blue { background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.35); color: var(--blue-bright); }
      .stage-green { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.35); color: var(--green-bright); }
      .link-arrow {
        flex: 0 0 32px;
        position: relative;
      }
      .link-arrow::before {
        content: '';
        position: absolute;
        top: 50%; left: 0; right: 0;
        height: 2px;
        background: repeating-linear-gradient(90deg, var(--gray) 0 6px, transparent 6px 12px);
        transform: translateY(-50%);
      }
      .link-arrow::after {
        content: '';
        position: absolute;
        top: 50%; right: 4px;
        width: 8px; height: 8px;
        border-right: 2px solid var(--gray);
        border-top: 2px solid var(--gray);
        transform: translateY(-50%) rotate(45deg);
      }

      /* Form */
      .form-wrap {
        background: var(--dark-card);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: clamp(1.5rem, 2.5vw, 2.25rem);
        position: relative;
        max-width: 540px;
        margin-left: auto;
        margin-right: auto;
        text-align: left;
      }
      .form-wrap::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--orange), var(--blue), var(--green));
        border-radius: 16px 16px 0 0;
      }
      .form-label {
        font-family: var(--font-mono);
        font-size: clamp(0.95rem, 1.1vw, 1.05rem);
        color: var(--gray-light);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .form-label .prompt { color: var(--orange); font-weight: 700; }
      .form-label .cursor {
        color: var(--orange);
        animation: blink 1.1s step-end infinite;
        margin-left: 0.15rem;
      }
      @keyframes blink { 50% { opacity: 0; } }
      .kit-form-container {
        margin-bottom: 1rem;
      }
      /* Tame Kit's default form to fit our aesthetic */
      .kit-form-container :global(form) {
        background: transparent !important;
        padding: 0 !important;
        border: 0 !important;
        max-width: none !important;
      }
      .kit-form-container :global(.formkit-input) {
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.12) !important;
        color: var(--white) !important;
        font-family: var(--font-mono) !important;
        border-radius: 8px !important;
      }
      .kit-form-container :global(.formkit-input::placeholder) {
        color: var(--gray) !important;
        opacity: 0.45 !important;
        font-family: var(--font-mono) !important;
      }
      .kit-form-container :global(.formkit-input::-webkit-input-placeholder) {
        color: var(--gray) !important;
        opacity: 0.45 !important;
      }
      .kit-form-container :global(.formkit-input::-moz-placeholder) {
        color: var(--gray) !important;
        opacity: 0.45 !important;
      }
      .kit-form-container :global(button[type="submit"]) {
        background: linear-gradient(90deg, var(--orange), var(--green)) !important;
        color: #000 !important;
        font-family: var(--font-heading) !important;
        font-weight: 700 !important;
        border-radius: 100px !important;
        border: 0 !important;
      }
      .form-fineprint {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--gray);
        line-height: 1.6;
        margin-top: 0.5rem;
      }
      .form-fineprint strong { color: var(--green-bright); }
      .form-trust-note {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--gray);
        text-align: center;
        opacity: 0.55;
        max-width: 540px;
        margin: 1.25rem auto 0;
        line-height: 1.6;
      }

      /* ============ BENEFITS ============ */
      .cohort-benefits {
        background: var(--dark-card);
        padding: clamp(13rem, 19vw, 18rem) 2.5rem clamp(4rem, 7vw, 6rem);
        position: relative;
        overflow: hidden;
      }
      .bg-text-benefits { top: 5.5rem; left: -0.5rem; }
      .benefits-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 3rem;
      }
      .benefit-card {
        background: var(--dark);
        border-radius: 18px;
        padding: clamp(2rem, 3vw, 2.5rem);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.06);
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease, border-color 0.4s ease;
      }
      .benefit-card:hover { transform: translateY(-6px); }
      .benefit-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
      }
      .bc-orange::before { background: var(--orange); }
      .bc-orange:hover { border-color: rgba(255,107,53,0.5); box-shadow: 0 20px 60px rgba(255,107,53,0.18); }
      .bc-blue::before { background: var(--blue); }
      .bc-blue:hover { border-color: rgba(59,130,246,0.5); box-shadow: 0 20px 60px rgba(59,130,246,0.18); }
      .bc-green::before { background: var(--green); }
      .bc-green:hover { border-color: rgba(16,185,129,0.5); box-shadow: 0 20px 60px rgba(16,185,129,0.18); }

      .bc-num {
        font-family: var(--font-heading);
        font-size: clamp(2.25rem, 3.4vw, 3rem);
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0.75rem;
        opacity: 0.25;
      }
      .bc-orange .bc-num { color: var(--orange); }
      .bc-blue .bc-num { color: var(--blue); }
      .bc-green .bc-num { color: var(--green); }
      .bc-title {
        font-family: var(--font-heading);
        font-size: clamp(1.4rem, 2vw, 1.7rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.85rem;
        color: var(--white);
      }
      .bc-body {
        font-size: clamp(0.95rem, 1.1vw, 1.02rem);
        line-height: 1.65;
        color: var(--gray-light);
        margin-bottom: 1.5rem;
      }
      .bc-tag {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        padding: 0.35rem 0.7rem;
        border-radius: 4px;
      }
      .bc-orange .bc-tag { background: rgba(255,107,53,0.12); color: var(--orange-bright); }
      .bc-blue .bc-tag { background: rgba(59,130,246,0.12); color: var(--blue-bright); }
      .bc-green .bc-tag { background: rgba(16,185,129,0.12); color: var(--green-bright); }

      .principle-grid {
        display: grid;
        grid-template-columns: repeat(4, 12px);
        gap: 4px;
        margin-bottom: 1rem;
      }
      .principle-grid span {
        width: 12px; height: 12px;
        background: rgba(16,185,129,0.35);
        border-radius: 2px;
      }
      .principle-grid span:nth-child(odd) { background: rgba(16,185,129,0.6); }

      .benefits-fine {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--gray);
        text-align: center;
        padding: 1rem 1.5rem;
        background: rgba(255,255,255,0.02);
        border: 1px dashed rgba(255,255,255,0.08);
        border-radius: 10px;
        max-width: 28rem;
        margin: 0 auto;
        line-height: 1.6;
      }
      .bf-icon {
        color: var(--orange);
        margin-right: 0.4rem;
        font-weight: 700;
      }

      /* ============ ABOUT ============ */
      .cohort-about {
        background: var(--dark);
        padding: clamp(4rem, 7vw, 6rem) 2.5rem clamp(7rem, 12vw, 10rem);
        position: relative;
        overflow: hidden;
      }
      .bg-text-about { top: -1rem; right: -1rem; }
      .about-inner {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 4rem;
        align-items: center;
      }
      .about-portrait {
        position: relative;
        max-width: 400px;
        margin: 0 auto;
        width: 100%;
        aspect-ratio: 4/5;
      }
      .portrait-frame {
        width: 100%;
        height: 100%;
        background: var(--dark-card) url('/images/mark-shust-bg.jpg') center/cover no-repeat;
        position: relative;
        overflow: hidden;
        clip-path: polygon(
          0% 5%, 5% 5%, 5% 0%,
          68% 0%, 68% 2.5%, 95% 2.5%, 95% 0%, 100% 0%,
          100% 62%, 97.5% 62%, 97.5% 68%, 100% 68%,
          100% 95%, 95% 95%, 95% 100%,
          32% 100%, 32% 97.5%, 5% 97.5%, 5% 100%, 0% 100%,
          0% 68%, 2.5% 68%, 2.5% 62%, 0% 62%
        );
      }
      .portrait-frame::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,107,53,0.12) 0%, rgba(59,130,246,0.08) 50%, rgba(16,185,129,0.12) 100%);
        z-index: 5;
        pointer-events: none;
      }
      .portrait-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 24px 24px;
        z-index: 1;
      }
      .portrait-scanline {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,107,53,0.3), rgba(59,130,246,0.3), rgba(16,185,129,0.3), transparent);
        z-index: 2;
        animation: scanDown 14s linear infinite;
      }
      .portrait-img {
        position: absolute;
        inset: 0;
        background: url('/images/mark-shust-over.png') center/cover no-repeat;
        z-index: 3;
        pointer-events: none;
      }
      @keyframes scanDown {
        0% { top: -1px; opacity: 0.2; }
        15% { opacity: 0.6; }
        50% { opacity: 0.4; }
        100% { top: 100%; opacity: 0.2; }
      }
      .corner { position: absolute; width: 22px; height: 22px; z-index: 4; }
      .corner::before, .corner::after { content: ''; position: absolute; }
      .corner.tl { top: -8px; left: -8px; }
      .corner.tl::before { width: 22px; height: 3px; top: 0; left: 0; background: var(--orange); }
      .corner.tl::after { width: 3px; height: 22px; top: 0; left: 0; background: var(--orange); }
      .corner.tr { top: -8px; right: -8px; }
      .corner.tr::before { width: 22px; height: 3px; top: 0; right: 0; background: var(--blue); }
      .corner.tr::after { width: 3px; height: 22px; top: 0; right: 0; background: var(--blue); }
      .corner.bl { bottom: -8px; left: -8px; }
      .corner.bl::before { width: 22px; height: 3px; bottom: 0; left: 0; background: var(--green); }
      .corner.bl::after { width: 3px; height: 22px; bottom: 0; left: 0; background: var(--green); }
      .corner.br { bottom: -8px; right: -8px; }
      .corner.br::before { width: 22px; height: 3px; bottom: 0; right: 0; background: #444; }
      .corner.br::after { width: 3px; height: 22px; bottom: 0; right: 0; background: #444; }

      .float-tag {
        position: absolute;
        top: -16px; left: -25px;
        background: var(--orange);
        color: #000;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 0.45rem 0.9rem;
        border-radius: 6px;
        z-index: 6;
        box-shadow: 0 10px 35px rgba(255,107,53,0.35);
        animation: floatLabel 6s ease-in-out infinite;
      }
      @keyframes floatLabel {
        0%, 100% { transform: translateY(0) rotate(-2deg); }
        50% { transform: translateY(-6px) rotate(1deg); }
      }
      .float-code {
        position: absolute;
        bottom: -22px; right: -25px;
        background: rgba(20,20,28,0.92);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.85rem 1.2rem;
        border-radius: 10px;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        z-index: 6;
        box-shadow: 0 16px 50px rgba(0,0,0,0.6);
        animation: floatBadge 5s ease-in-out infinite;
      }
      @keyframes floatBadge {
        0%, 100% { transform: translateY(0) rotate(1deg); }
        50% { transform: translateY(-8px) rotate(-1deg); }
      }
      .fc-vr { color: var(--orange-bright); }
      .fc-str { color: var(--green-bright); }
      .fc-punc { color: var(--gray); }

      .about-title {
        font-family: var(--font-heading);
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        line-height: 0.98;
        letter-spacing: -0.04em;
        margin-bottom: 1.75rem;
        color: var(--white);
      }
      .about-body {
        font-size: clamp(1rem, 1.2vw, 1.1rem);
        line-height: 1.75;
        color: var(--gray-light);
        margin-bottom: 1.25rem;
        max-width: 600px;
      }
      .about-body a {
        color: var(--orange);
        text-decoration: none;
        border-bottom: 1px dashed rgba(255,107,53,0.5);
      }
      .about-body a:hover {
        color: var(--orange-bright);
        border-bottom-color: var(--orange-bright);
      }
      .about-stats {
        display: flex;
        gap: 2.5rem;
        margin-top: 2rem;
        flex-wrap: wrap;
      }
      .as-block { text-align: left; }
      .as-num {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 3vw, 2.5rem);
        font-weight: 700;
        color: var(--white);
        line-height: 1;
      }
      .as-plus { color: var(--orange); }
      .as-label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--gray);
        margin-top: 0.4rem;
      }

      /* ============ FINAL CTA ============ */
      .cohort-final {
        background: var(--dark-card);
        padding: clamp(13rem, 19vw, 18rem) 2.5rem clamp(7rem, 12vw, 10rem);
        position: relative;
        overflow: hidden;
        text-align: center;
      }
      .bg-text-final { top: 6rem; left: 50%; transform: translateX(-50%); white-space: nowrap; }
      .final-inner {
        max-width: 720px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }
      .cohort-final .section-label {
        text-align: center;
      }
      .final-title {
        font-family: var(--font-heading);
        font-size: clamp(3rem, 6vw, 5rem);
        font-weight: 700;
        line-height: 0.95;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
        color: var(--white);
      }
      .final-body {
        font-size: clamp(1.05rem, 1.3vw, 1.2rem);
        line-height: 1.7;
        color: var(--gray-light);
        margin: 0 auto 1.25rem;
        max-width: 33rem;
        text-align: left;
      }
      .final-body + .final-body { margin-bottom: 2.5rem; }
      /* ============ Responsive ============ */
      @media (max-width: 1024px) {
        .benefits-grid { grid-template-columns: 1fr; }
        .about-inner { grid-template-columns: 1fr; gap: 5rem; }
        .about-portrait { max-width: 340px; }
        .about-stats { justify-content: flex-start; }
      }
      @media (max-width: 768px) {
        .cohort-hero { padding: 7.5rem 1.25rem 6rem; min-height: auto; }
        .cohort-benefits, .cohort-about, .cohort-final { padding: 6rem 1.25rem; }
        .schematic { padding: 1rem; gap: 0.4rem; }
        .stage { padding: 0.85rem 1rem; min-width: 90px; }
        .link-arrow { flex: 0 0 20px; }
        .float-tag, .float-code { display: none; }
      }
      @media (max-width: 480px) {
        .hero-title { font-size: clamp(2.5rem, 11vw, 3.5rem); }
        .schematic { flex-direction: column; }
        .link-arrow { flex: 0 0 20px; height: 20px; transform: rotate(90deg); }
      }
    </style>
  </body>
</html>
