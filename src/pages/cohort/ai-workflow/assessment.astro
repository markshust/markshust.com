---
import BaseHead from '../../../components/BaseHead.astro';
import Nav from '../../../components/Nav.astro';
import DiagonalBand from '../../../components/DiagonalBand.astro';
import Footer from '../../../components/Footer.astro';

const sections = [
  {
    num: '01',
    title: 'Planning vs. Execution',
    questions: [
      'Do you have an explicit planning phase that produces structured output (like a task list, spec, or plan file) <em>before</em> code generation begins?',
      'Can your AI tooling clearly distinguish between “we’re still figuring this out” and “go build it”, without you having to manually re-explain context every time?',
    ],
  },
  {
    num: '02',
    title: 'Workflow Stages',
    questions: [
      'Are the stages of your AI development workflow explicitly named and visible, and not just implicit in your head?',
      'Could a teammate (or future-you) describe each stage’s job in one sentence?',
    ],
  },
  {
    num: '03',
    title: 'Inputs, Outputs, Handoffs',
    questions: [
      'Does each stage produce a defined output the next stage can consume <em>without guessing</em> what was meant?',
      'Are your AI tasks defined with explicit acceptance criteria (tests, behavioral contracts, “done looks like X”) before work begins?',
    ],
  },
  {
    num: '04',
    title: 'Humans in the Loop',
    questions: [
      'Have you deliberately decided where human checkpoints belong, or do they just happen by accident wherever you got nervous?',
      'Is there at least one stage where whatever the AI proposes is explicitly approved, before it gets executed?',
    ],
  },
  {
    num: '05',
    title: 'Dependencies and Parallelism',
    questions: [
      'Does your workflow define explicit dependencies between tasks to take advantage of parallelization?',
      'When the downstream work of your AI fails, can you trace back upstream to identify the exact task that was implicitly assumed complete, but wasn’t?',
    ],
  },
  {
    num: '06',
    title: 'Bounded Responsibility',
    questions: [
      'Do your AI agents/subagents have narrowly-scoped jobs, or do you mostly run commands from a general-purpose prompt?',
      'Do you have success criteria defined for each bounded role (so the agent knows when to stop)?',
    ],
  },
  {
    num: '07',
    title: 'Review and Quality Gates',
    questions: [
      'Do you have an automated <em>pre-implementation</em> review gate that critiques your plans before any code gets written?',
      'Do you have an automated <em>post-implementation</em> review gate that enforces coding guidelines and standards, and that runs tests after code is generated but before it’s accepted?',
    ],
  },
  {
    num: '08',
    title: 'Portability',
    questions: [
      'Could you move your <em>exact</em> development workflow to another project or codebase tomorrow, without rebuilding the architecture from scratch?',
    ],
  },
];

let qCounter = 0;
const indexedSections = sections.map((s) => ({
  ...s,
  questions: s.questions.map((q) => {
    qCounter += 1;
    return { num: String(qCounter).padStart(2, '0'), text: q, id: qCounter };
  }),
}));

const totalQuestions = qCounter;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title="AI Workflow Architecture Self-Assessment · Mark Shust"
      description="Is your AI coding workflow designed, or improvised? Find out in 5 minutes. A 15-question diagnostic against the 8 architectural principles taught in the cohort."
      image="/images/og-cohort.png"
    />
  </head>
  <body>
    <div class="site-wrapper">
      <Nav homepage={false} />

      <!-- Sticky progress bar -->
      <div class="progress-shell" id="progressShell" aria-hidden="true">
        <div class="progress-track">
          <div class="progress-fill" id="progressFill"></div>
        </div>
        <div class="progress-meta">
          <span class="pm-left">
            <span class="pm-prompt">&gt;</span>
            <span class="pm-label">progress</span>
          </span>
          <span class="pm-right">
            <span class="pm-count" id="progressCount">00</span>
            <span class="pm-divider">/</span>
            <span class="pm-total">{String(totalQuestions).padStart(2, '0')}</span>
          </span>
        </div>
      </div>

      <!-- ============ HERO ============ -->
      <section class="aw-hero">
        <div class="blueprint-grid"></div>
        <div class="bg-text">/ASSESS</div>
        <div class="hero-inner">
          <div class="hero-meta-row">
            <span class="hero-mono-label">02 / Self-Assessment · 5 min</span>
            <span class="seat-pill"><span class="seat-dot"></span>{totalQuestions} questions</span>
          </div>
          <h1 class="hero-title">
            is your AI workflow<br>
            <span class="ht-grad">designed</span>, or improvised?
          </h1>
          <p class="hero-lead">
            Most developers using AI to assist with coding have <em>some</em> workflow; they just can’t see it. This assessment makes it visible.
          </p>
          <p class="hero-lead">
            Answer YES or NO to each question. When you’re finished, your score reveals the gaps in your workflow architecture.
          </p>

          <a href="#quiz" class="hero-start">
            <span class="hs-prompt">&gt;</span>
            <span class="hs-label">start_assessment</span>
            <span class="hs-cursor">_</span>
          </a>
        </div>
      </section>

      <DiagonalBand variant="1" />

      <!-- ============ QUIZ ============ -->
      <section class="aw-quiz" id="quiz">
        <div class="bg-text bg-text-quiz">AUDIT</div>
        <div class="quiz-inner">
          {indexedSections.map((section) => (
            <div class="quiz-section">
              <div class="qs-head">
                <div class="qs-num">{section.num}</div>
                <div class="qs-title">{section.title}</div>
                <div class="qs-rule"></div>
              </div>

              {section.questions.map((q) => (
                <article class="q-card" id={`q${q.num}`} data-qid={q.id}>
                  <div class="q-meta">
                    <span class="q-num">Q{q.num}</span>
                    <span class="q-status" data-status>-</span>
                  </div>
                  <p class="q-text" set:html={q.text}></p>
                  <div class="q-choices" role="radiogroup" aria-label={`Question ${q.num}`}>
                    <button
                      type="button"
                      class="q-btn q-yes"
                      data-answer="yes"
                      data-qid={q.id}
                      aria-pressed="false"
                    >
                      <span class="qb-key">Y</span>
                      <span class="qb-text">YES</span>
                    </button>
                    <button
                      type="button"
                      class="q-btn q-no"
                      data-answer="no"
                      data-qid={q.id}
                      aria-pressed="false"
                    >
                      <span class="qb-key">N</span>
                      <span class="qb-text">NO</span>
                    </button>
                  </div>
                </article>
              ))}
            </div>
          ))}
        </div>
      </section>

      <DiagonalBand variant="2" />

      <!-- ============ RESULT ============ -->
      <section class="aw-result" id="result">
        <div class="bg-text bg-text-result">SCORE</div>
        <div class="result-inner">
          <!-- Locked state (incomplete) -->
          <div class="result-locked" id="resultLocked">
            <div class="rl-grid"></div>
            <div class="rl-icon" aria-hidden="true">
              <span class="rl-bar"></span><span class="rl-bar"></span><span class="rl-bar"></span>
            </div>
            <div class="section-label">04 / Awaiting input</div>
            <h2 class="rl-title">
              your result is <span class="ht-grad">locked</span>.
            </h2>
            <p class="rl-body">
              Answer all <span id="lockedTotal">{totalQuestions}</span> questions to reveal your workflow architecture score and the diagnostic that comes with it.
            </p>
            <p class="rl-fineprint">
              <span id="lockedCount">0</span> / {totalQuestions} answered
            </p>
          </div>

          <!-- Email-gate state (complete + locked) -->
          <div class="email-gate" id="resultEmailGate" hidden>
            <div class="eg-stripe"></div>
            <div class="eg-meta">
              <span class="eg-mono">&gt; result.locked()</span>
              <span class="eg-pill">FOUNDING · COHORT #1</span>
            </div>
            <h2 class="eg-heading">
              your assessment is <span class="ht-grad">ready</span>.
            </h2>
            <p class="eg-body">
              Enter your email to see your score and lock in your founding-member spot.
            </p>

            <div class="eg-teaser" aria-hidden="true">
              <div class="eg-teaser-row">
                <span class="eg-teaser-label">your score</span>
                <span class="eg-teaser-redacted">
                  <span class="eg-block"></span><span class="eg-block"></span>
                  <span class="eg-teaser-divider">/</span>
                  <span class="eg-teaser-total">{totalQuestions}</span>
                </span>
              </div>
              <div class="eg-teaser-row">
                <span class="eg-teaser-label">your tier</span>
                <span class="eg-teaser-locked">[ LOCKED ]</span>
              </div>
            </div>

            <div class="eg-specs">
              <div class="eg-spec">
                <span class="eg-spec-label">Founding rate</span>
                <span class="eg-spec-val eg-spec-price">$999</span>
              </div>
              <div class="eg-spec">
                <span class="eg-spec-label">Seats</span>
                <span class="eg-spec-val">10</span>
              </div>
              <div class="eg-spec">
                <span class="eg-spec-label">Application</span>
                <span class="eg-spec-val">required</span>
              </div>
              <div class="eg-spec">
                <span class="eg-spec-label">Runs</span>
                <span class="eg-spec-val">June 2026</span>
              </div>
            </div>

            <div class="eg-form-label">
              <span class="eg-form-prompt">&gt;</span>
              <span>see_my_score</span>
              <span class="eg-form-cursor">_</span>
            </div>
            <div class="kit-form-container" id="emailGateKitForm">
              <script async data-uid="56242fd89c" src="https://macademy.kit.com/56242fd89c/index.js" is:inline></script>
            </div>
            <p class="eg-fineprint">
              When registration opens, you'll be emailed first with the application link and the founding rate locked in. No spam.
            </p>
          </div>

          <!-- Revealed state -->
          <div class="result-revealed" id="resultRevealed" hidden>
            <!-- Post-unlock founding-offer info (no form, just confirmation + tier copy) -->
            <div class="founding-card" id="foundingCard">
              <div class="fc-stripe"></div>
              <div class="fc-meta">
                <span class="fc-mono">&gt; cohort.offer_unlocked()</span>
                <span class="fc-pill">FOUNDING · COHORT #1</span>
              </div>
              <h3 class="fc-heading">
                your personalized<br>cohort <span class="ht-grad">offer</span>.
              </h3>
              <p class="fc-offer-prelude">
                Based on your score (<span class="fc-tier-inline" id="offerTier">-</span>), here's what Cohort #1 will do for you specifically:
              </p>
              <p class="fc-offer-hook" id="offerHookBody">-</p>

              <div class="fc-specs">
                <div class="fc-spec">
                  <span class="fc-spec-label">Founding rate</span>
                  <span class="fc-spec-val fc-spec-price">$999</span>
                </div>
                <div class="fc-spec">
                  <span class="fc-spec-label">Seats</span>
                  <span class="fc-spec-val">10</span>
                </div>
                <div class="fc-spec">
                  <span class="fc-spec-label">Application</span>
                  <span class="fc-spec-val">required</span>
                </div>
                <div class="fc-spec">
                  <span class="fc-spec-label">Runs</span>
                  <span class="fc-spec-val">June 2026</span>
                </div>
              </div>

              <div class="fc-confirmed">
                <span class="fc-confirmed-dot"></span>
                <span class="fc-confirmed-text">
                  You're on the founding-member shortlist. When applications open, you'll get the link first, with the $999 founding rate locked in.
                </span>
              </div>
            </div>

            <div class="section-label rr-score-label">05 / Your score</div>
            <div class="result-card">
              <div class="rc-stripe"></div>
              <div class="rc-grid"></div>
              <div class="rc-meta">
                <span class="rc-mono">&gt; result.compute()</span>
                <span class="rc-tier-pill" id="tierPill">-</span>
              </div>
              <div class="rc-score">
                <span class="rc-score-num" id="scoreNum">0</span>
                <span class="rc-score-divider">/</span>
                <span class="rc-score-total">{totalQuestions}</span>
                <span class="rc-score-label">YES</span>
              </div>
              <div class="rc-bar">
                <div class="rc-bar-fill" id="scoreBarFill"></div>
              </div>
              <h2 class="rc-headline" id="resultHeadline">-</h2>
              <p class="rc-body" id="resultBody">-</p>
              <div class="rc-meaning">
                <p class="rc-meaning-label">What this means</p>
                <p class="rc-meaning-body">
                  Every <strong>NO</strong> above is a future bug, future hallucination, or future “did AI do that?” The 8 architectural principles behind this assessment are <strong>exactly</strong> what the cohort teaches, applied to <em>your</em> codebase, not a toy demo.
                </p>
              </div>

              <div class="rc-actions">
                <button type="button" class="rc-cta-ghost" id="resetBtn">
                  <span class="rcg-prompt">&gt;</span>
                  <span class="rcg-text">retake_assessment</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <Footer />
    </div>

    <script is:inline define:vars={{ totalQuestions }}>
      (function () {
        const STORAGE_KEY = 'aw-assessment-v1';
        const UNLOCK_KEY = 'aw-unlocked-v1';
        const total = totalQuestions;
        const answers = new Map();

        const tiers = [
          {
            min: 13,
            max: 15,
            key: 'strong',
            pill: 'STRONG',
            headline: 'strong workflow architecture.',
            body: 'You’re operating at a high level. The cohort will sharpen the edges and expose blind spots you’ve earned the right to see.',
            offerHook: 'You’re already operating at a high level. The cohort sharpens edges and exposes blind spots you’ve earned the right to see. Founding rate locks you into the small group of advanced operators in Cohort #1.',
          },
          {
            min: 9,
            max: 12,
            key: 'solid',
            pill: 'SOLID',
            headline: 'solid foundation, several gaps.',
            body: 'You have real structure in place, but the seams are showing. The cohort closes the gaps systematically and gives you the pieces you know are missing.',
            offerHook: 'You’ve got structure, but the seams are showing. Cohort #1 closes those gaps systematically and gives you the missing pieces you already know are missing, applied to your codebase, not a template.',
          },
          {
            min: 5,
            max: 8,
            key: 'improv',
            pill: 'IMPROVISING',
            headline: 'mostly improvising.',
            body: 'You feel the chaos because you know what needs to be done, but the system isn’t designed yet. The cohort is built for exactly this: turning ad hoc into a well-defined architecture within five weeks.',
            offerHook: 'You’re feeling the chaos because you know what good looks like, but the system just isn’t designed yet. Cohort #1 is built for exactly this score. Five weeks, applied to your real codebase, you leave with the architecture installed.',
          },
          {
            min: 0,
            max: 4,
            key: 'early',
            pill: 'EARLY',
            headline: 'you’re early.',
            body: 'And early is the best time to install architecture, before chaos calcifies into bad habits. The cohort gives you the system before bad patterns set, applied to your real code from the start.',
            offerHook: 'Early is the best time to install architecture, before bad patterns calcify. Cohort #1 gives you the system from day one, applied to your real code, with the founding rate locked in.',
          },
        ];

        const $ = (sel) => document.querySelector(sel);
        const fill = $('#progressFill');
        const countEl = $('#progressCount');
        const lockedCountEl = $('#lockedCount');
        const resultLocked = $('#resultLocked');
        const resultEmailGate = $('#resultEmailGate');
        const resultRevealed = $('#resultRevealed');
        const scoreNumEl = $('#scoreNum');
        const scoreBarFill = $('#scoreBarFill');
        const tierPill = $('#tierPill');
        const headlineEl = $('#resultHeadline');
        const bodyEl = $('#resultBody');
        const offerTierEl = $('#offerTier');
        const offerHookEl = $('#offerHookBody');
        const foundingCardEl = $('#foundingCard');
        const card = () => document.querySelector('.result-card');

        let booted = false;
        let lastComplete = false;

        function tierFor(score) {
          return tiers.find((t) => score >= t.min && score <= t.max) || tiers[3];
        }

        function isUnlocked() {
          try { return localStorage.getItem(UNLOCK_KEY) === '1'; } catch (_) { return false; }
        }

        function setUnlocked() {
          try { localStorage.setItem(UNLOCK_KEY, '1'); } catch (_) {}
        }

        function load() {
          try {
            const raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return;
            const obj = JSON.parse(raw);
            Object.entries(obj).forEach(([k, v]) => {
              const id = parseInt(k, 10);
              if (!Number.isNaN(id) && (v === 'yes' || v === 'no')) {
                answers.set(id, v);
              }
            });
          } catch (_) {}
        }

        function persist() {
          try {
            const obj = {};
            answers.forEach((v, k) => { obj[k] = v; });
            localStorage.setItem(STORAGE_KEY, JSON.stringify(obj));
          } catch (_) {}
        }

        function applyAnswerUI(id, value) {
          const card = document.querySelector(`.q-card[data-qid="${id}"]`);
          if (!card) return;
          card.classList.toggle('answered', !!value);
          card.classList.toggle('answered-yes', value === 'yes');
          card.classList.toggle('answered-no', value === 'no');
          card.querySelectorAll('.q-btn').forEach((b) => {
            const isSelected = b.dataset.answer === value;
            b.classList.toggle('selected', isSelected);
            b.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
          });
          const status = card.querySelector('[data-status]');
          if (status) {
            if (value === 'yes') status.textContent = 'YES';
            else if (value === 'no') status.textContent = 'NO';
            else status.textContent = '-';
          }
        }

        function updateProgress() {
          const answered = answers.size;
          const yesCount = Array.from(answers.values()).filter((v) => v === 'yes').length;
          const pct = (answered / total) * 100;
          fill.style.width = pct + '%';
          countEl.textContent = String(answered).padStart(2, '0');
          if (lockedCountEl) lockedCountEl.textContent = String(answered);

          const isComplete = answered >= total;
          const unlocked = isUnlocked();

          if (!isComplete) {
            if (resultLocked) resultLocked.hidden = false;
            if (resultEmailGate) resultEmailGate.hidden = true;
            if (resultRevealed) resultRevealed.hidden = true;
          } else if (!unlocked) {
            if (resultLocked) resultLocked.hidden = true;
            if (resultEmailGate) resultEmailGate.hidden = false;
            if (resultRevealed) resultRevealed.hidden = true;
            populateResult(yesCount);
          } else {
            if (resultLocked) resultLocked.hidden = true;
            if (resultEmailGate) resultEmailGate.hidden = true;
            if (resultRevealed) resultRevealed.hidden = false;
            populateResult(yesCount);
          }

          // Auto-scroll to the result only on the transition from incomplete → complete,
          // and only after the page has finished initial hydration (so we don't yank the
          // viewport on a refresh when all 15 were already saved in localStorage).
          if (booted && isComplete && !lastComplete) {
            const target = document.getElementById('result');
            if (target) {
              setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 120);
            }
          }
          lastComplete = isComplete;
        }

        function populateResult(yesCount) {
          const tier = tierFor(yesCount);
          scoreNumEl.textContent = String(yesCount);
          scoreBarFill.style.width = (yesCount / total) * 100 + '%';
          tierPill.textContent = tier.pill;
          tierPill.dataset.tier = tier.key;
          headlineEl.textContent = tier.headline;
          bodyEl.textContent = tier.body;
          if (offerTierEl) offerTierEl.textContent = tier.pill.toLowerCase();
          if (offerHookEl) offerHookEl.textContent = tier.offerHook;
          if (foundingCardEl) foundingCardEl.dataset.tier = tier.key;
          const c = card();
          if (c) c.dataset.tier = tier.key;
        }

        function watchKitForUnlock() {
          const container = document.getElementById('emailGateKitForm');
          if (!container) return;
          let inputAppeared = false;
          let triggered = false;
          const check = () => {
            if (triggered) return;
            const input = container.querySelector('.formkit-input');
            const success = container.querySelector('[data-element="success"], .formkit-success, .formkit-alert-success');
            if (input) inputAppeared = true;
            const successVisible = !!success && !success.hidden &&
              getComputedStyle(success).display !== 'none' &&
              getComputedStyle(success).visibility !== 'hidden';
            const inputDisappeared = inputAppeared && !input;
            if (successVisible || inputDisappeared) {
              triggered = true;
              obs.disconnect();
              onUnlock();
            }
          };
          const obs = new MutationObserver(check);
          obs.observe(container, { childList: true, subtree: true, attributes: true });
        }

        function onUnlock() {
          setUnlocked();
          // Pause so user reads Kit's thank-you message, then reveal the score.
          setTimeout(() => {
            updateProgress();
            setTimeout(() => {
              const target = document.querySelector('.rr-score-label') || document.querySelector('.result-card');
              if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 200);
          }, 1100);
        }

        function setAnswer(id, value) {
          if (answers.get(id) === value) {
            // Toggle off
            answers.delete(id);
            applyAnswerUI(id, null);
          } else {
            answers.set(id, value);
            applyAnswerUI(id, value);
          }
          persist();
          updateProgress();
        }

        function bind() {
          document.querySelectorAll('.q-btn').forEach((btn) => {
            btn.addEventListener('click', () => {
              const id = parseInt(btn.dataset.qid, 10);
              const value = btn.dataset.answer;
              setAnswer(id, value);
            });
          });

          const resetBtn = document.getElementById('resetBtn');
          if (resetBtn) {
            resetBtn.addEventListener('click', () => {
              answers.clear();
              persist();
              document.querySelectorAll('.q-card').forEach((c) => {
                c.classList.remove('answered', 'answered-yes', 'answered-no');
                c.querySelectorAll('.q-btn').forEach((b) => {
                  b.classList.remove('selected');
                  b.setAttribute('aria-pressed', 'false');
                });
                const status = c.querySelector('[data-status]');
                if (status) status.textContent = '-';
              });
              updateProgress();
              const firstQ = document.getElementById('q01');
              if (firstQ) firstQ.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
          }

          // Keyboard shortcuts: Y / N when a question card is focused-within
          document.addEventListener('keydown', (e) => {
            if (e.metaKey || e.ctrlKey || e.altKey) return;
            const tag = (e.target && e.target.tagName) || '';
            if (tag === 'INPUT' || tag === 'TEXTAREA') return;
            const k = e.key.toLowerCase();
            if (k !== 'y' && k !== 'n') return;
            // Find the question card in the middle of the viewport
            const cards = Array.from(document.querySelectorAll('.q-card'));
            const mid = window.innerHeight / 2;
            let best = null;
            let bestDist = Infinity;
            cards.forEach((c) => {
              const r = c.getBoundingClientRect();
              const center = r.top + r.height / 2;
              const dist = Math.abs(center - mid);
              if (dist < bestDist) { bestDist = dist; best = c; }
            });
            if (best) {
              const id = parseInt(best.dataset.qid, 10);
              setAnswer(id, k === 'y' ? 'yes' : 'no');
            }
          });
        }

        function applyQueryPreFill() {
          try {
            const params = new URLSearchParams(window.location.search);
            const q1 = params.get('q1');
            if (q1 === 'yes' || q1 === 'no') {
              answers.set(1, q1);
              persist();
            }
            if (params.has('q1')) {
              const newUrl = window.location.pathname + window.location.hash;
              history.replaceState({}, '', newUrl);
            }
          } catch (_) {}
        }

        // Init
        load();
        applyQueryPreFill();
        answers.forEach((v, id) => applyAnswerUI(id, v));
        updateProgress();
        booted = true;
        bind();
        if (!isUnlocked()) watchKitForUnlock();

        // Show progress shell only after slight scroll, like a sticky badge that fades in
        const shell = document.getElementById('progressShell');
        const onScroll = () => {
          if (window.scrollY > 60) shell.classList.add('visible');
          else shell.classList.remove('visible');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        // Customize Kit form placeholder once Kit injects the form
        const setKitPlaceholder = () => {
          document.querySelectorAll('.kit-form-container .formkit-input').forEach((input) => {
            if (input.placeholder !== 'Email address') {
              input.placeholder = 'Email address';
              input.setAttribute('aria-label', 'Email address');
            }
          });
        };
        document.querySelectorAll('.kit-form-container').forEach((container) => {
          new MutationObserver(setKitPlaceholder).observe(container, { childList: true, subtree: true });
        });
        setKitPlaceholder();
      })();
