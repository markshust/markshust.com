---
interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  items: FAQItem[];
  label?: string;
  title?: string;
  highlight?: string;
}

const {
  items,
  label = '05 / Questions',
  title = 'frequently',
  highlight = 'asked',
} = Astro.props;
---

<section class="faq-section">
  <div class="bg-text bg-text-faq">FAQ</div>
  <div class="faq-inner">
    <div class="faq-head reveal">
      <div class="section-label">{label}</div>
      <h2 class="faq-title">
        {title} <span class="highlight-orange">{highlight}</span>.
      </h2>
    </div>

    <div class="faq-list">
      {items.map((item, i) => (
        <details class={`faq-item reveal delay-${(i % 4) + 1}`}>
          <summary class="faq-q">
            <span class="faq-q-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="faq-q-text">{item.q}</span>
            <span class="faq-q-icon" aria-hidden="true">
              <span class="faq-q-icon-h"></span>
              <span class="faq-q-icon-v"></span>
            </span>
          </summary>
          <div class="faq-a" set:html={item.a}></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    background: var(--dark);
    padding: clamp(8rem, 13vw, 11rem) 2.5rem clamp(4rem, 7vw, 6rem);
    position: relative;
    overflow: hidden;
  }
  .bg-text-faq {
    position: absolute;
    top: 2rem;
    right: -1rem;
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 0.85;
    pointer-events: none;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.025);
    font-size: clamp(8rem, 18vw, 18rem);
  }
  .faq-inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .faq-head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .faq-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--white);
  }
  .highlight-orange { color: var(--orange); }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    background: var(--dark-card);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }
  .faq-item[open] {
    border-color: rgba(255, 107, 53, 0.35);
  }
  .faq-q {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.2s ease;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q:hover { background: rgba(255, 255, 255, 0.02); }
  .faq-q-num {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--orange);
    background: rgba(255, 107, 53, 0.1);
    border: 1px solid rgba(255, 107, 53, 0.25);
    padding: 0.3rem 0.55rem;
    border-radius: 6px;
  }
  .faq-q-text {
    flex: 1;
    font-family: var(--font-heading);
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--white);
    line-height: 1.4;
  }
  .faq-q-icon {
    flex-shrink: 0;
    position: relative;
    width: 14px;
    height: 14px;
    display: inline-block;
  }
  .faq-q-icon-h,
  .faq-q-icon-v {
    position: absolute;
    background: var(--orange);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .faq-q-icon-h {
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }
  .faq-q-icon-v {
    top: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }
  .faq-item[open] .faq-q-icon-v {
    transform: translateX(-50%) scaleY(0);
    opacity: 0;
  }
  .faq-a {
    padding: 0 1.25rem 1.25rem calc(1.25rem + 0.55rem * 2 + 2ch);
    font-size: clamp(0.95rem, 1.1vw, 1.02rem);
    line-height: 1.7;
    color: var(--gray-light);
  }
  .faq-a strong { color: var(--white); }
  .faq-a em { color: var(--orange-bright); font-style: italic; }
  .faq-a a {
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px dashed rgba(255, 107, 53, 0.5);
  }
  .faq-a a:hover {
    color: var(--orange-bright);
    border-bottom-color: var(--orange-bright);
  }

  @media (max-width: 768px) {
    .faq-section { padding: 7rem 1.25rem 4rem; }
    .faq-q { padding: 1rem; gap: 0.75rem; }
    .faq-a { padding: 0 1rem 1rem 1rem; }
  }
</style>
