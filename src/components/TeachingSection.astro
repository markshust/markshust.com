---
---

<section class="section-teaching" id="teaching">
  <div class="bg-text">TEACHING</div>
  <div class="section-inner">
    <div class="teaching-intro">
      <div class="reveal">
        <div class="section-label">03 / Teaching</div>
        <h2 class="section-title">learn.<br>build.<br><span class="highlight">ship</span>.</h2>
      </div>
      <p class="teaching-desc reveal delay-1">
        My passion shifted from consulting to teaching, and I share techniques and tricks I've learned along the way to help others learn too.
      </p>
      <div class="stats-row reveal delay-2">
        <div class="stat-block">
          <div class="stat-num"><span class="counter" data-target="20">0</span>+</div>
          <div class="stat-label">Courses</div>
        </div>
        <div class="stat-block">
          <div class="stat-num"><span class="counter" data-target="15000">0</span>+</div>
          <div class="stat-label">Students</div>
        </div>
        <div class="stat-block">
          <div class="stat-num"><span class="counter" data-target="25">0</span>+</div>
          <div class="stat-label">Years</div>
        </div>
      </div>
    </div>

    <div class="teaching-posters">
      <div class="academy-poster reveal delay-1">
        <a class="academy-logo-link" href="https://m.academy" target="_blank" rel="noreferrer">
          <div class="academy-logo"><span class="accent">M</span>.academy</div>
        </a>
        <div class="academy-sub">Magento &amp; Adobe Commerce Developer Training</div>
        <ul class="course-list">
          <li><span class="course-dot"></span><a href="https://m.academy/courses/magento-2-coding-kickstart/" target="_blank" rel="noreferrer">Magento 2 Coding Kickstart</a></li>
          <li><span class="course-dot"></span><a href="https://m.academy/courses/magento-2-theming/" target="_blank" rel="noreferrer">Magento 2 Power Theming</a></li>
          <li><span class="course-dot"></span><a href="https://m.academy/courses/knockoutjs-magento-2/" target="_blank" rel="noreferrer">Defeat Knockout.js in Magento 2</a></li>
          <li><span class="course-dot"></span><a href="https://m.academy/courses/customize-magento-2-checkout/" target="_blank" rel="noreferrer">Customize the Magento 2 Checkout</a></li>
          <li><span class="course-dot"></span><a href="https://m.academy/courses/ui-components-magento-2/" target="_blank" rel="noreferrer">UI Components in Magento 2</a></li>
          <li><span class="course-dot"></span><a href="https://m.academy/courses/magento-2-admin-grids-forms/" target="_blank" rel="noreferrer">Transform M2 Admin Grids &amp; Forms</a></li>
        </ul>
        <a class="academy-cta" href="https://m.academy" target="_blank" rel="noreferrer">
          Start learning
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <a class="cohort-poster reveal delay-2" href="/cohort/ai-workflow/">
        <div class="cohort-stripe"></div>
        <div class="cohort-meta-row">
          <span class="cohort-pill">COHORT 01</span>
          <span class="cohort-pill">JUNE 2026</span>
        </div>
        <div class="cohort-title">
          <span class="ct-line">AI Workflow</span>
          <span class="ct-line ct-grad">Architecture</span>
        </div>
        <div class="cohort-sub">Stop prompting.<br>Start architecting.</div>
        <ul class="cohort-axes">
          <li><span class="axis-dot orange"></span><span class="axis-label">5 weeks of live sessions</span></li>
          <li><span class="axis-dot blue"></span><span class="axis-label">10 seats only</span></li>
          <li><span class="axis-dot green"></span><span class="axis-label">Your real codebase</span></li>
        </ul>
        <span class="cohort-cta">
          Join the waitlist
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
.section-teaching {
  background: var(--green);
  color: #000;
  padding: clamp(5rem, 10vw, 9rem) 2.5rem;
  position: relative;
  overflow: hidden;
}
.section-teaching .bg-text {
  position: absolute;
  top: -0.5rem; right: -0.5rem;
  font-family: var(--font-heading);
  font-size: clamp(10rem, 22vw, 24rem);
  font-weight: 700;
  color: rgba(0,0,0,0.05);
  line-height: 0.85;
  pointer-events: none;
  letter-spacing: -0.05em;
}
.section-teaching::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
}
.section-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.section-label {
  font-family: var(--font-mono);
  font-size: clamp(0.8rem, 1vw, 0.9rem);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 0.75rem;
  opacity: 0.6;
}
.section-title {
  font-family: var(--font-heading);
  font-size: clamp(3.5rem, 7vw, 6rem);
  font-weight: 700;
  line-height: 0.95;
  letter-spacing: -0.04em;
  margin-bottom: 1.5rem;
  color: #000;
}
.section-title .highlight { color: #fff; }

.teaching-intro {
  max-width: 720px;
  margin-bottom: 3.5rem;
}
.teaching-desc {
  font-size: clamp(1.1rem, 1.4vw, 1.3rem);
  line-height: 1.75;
  color: rgba(0,0,0,0.7);
  max-width: 560px;
  margin-bottom: 2.5rem;
}
.stats-row { display: flex; gap: 2.5rem; flex-wrap: wrap; }
.stat-block { text-align: left; }
.stat-num {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 4.5vw, 3.5rem);
  font-weight: 700;
  color: #000;
  line-height: 1;
}
.stat-label {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: rgba(0,0,0,0.5);
  margin-top: 0.25rem;
}

.teaching-posters {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: stretch;
}

/* Shared poster surface */
.academy-poster,
.cohort-poster {
  background: var(--dark);
  color: var(--white);
  border-radius: 24px;
  padding: clamp(2.25rem, 3.5vw, 3rem);
  position: relative;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  cursor: pointer;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
}
.academy-poster:hover,
.cohort-poster:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 0 30px 80px rgba(0,0,0,0.5);
}

/* M.academy poster: green identity */
.academy-poster::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 0%, rgba(16,185,129,0.15), transparent 65%);
  pointer-events: none;
}
.academy-logo {
  font-family: var(--font-heading);
  font-size: clamp(2.25rem, 4vw, 3.25rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 0.5rem;
  position: relative;
  z-index: 1;
  color: var(--white);
}
.academy-logo .accent { color: var(--green); }
.academy-logo-link { text-decoration: none; }
.academy-sub {
  font-family: var(--font-mono);
  font-size: 1rem;
  color: var(--gray);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-bottom: 2rem;
  position: relative;
  z-index: 1;
}
.course-list {
  list-style: none;
  margin-bottom: 2rem;
  position: relative;
  z-index: 1;
  flex: 1;
}
.course-list li {
  font-size: clamp(0.9rem, 1.1vw, 1.05rem);
  padding: 0.8rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  gap: 0.8rem;
  color: var(--gray-light);
  transition: color 0.3s ease, padding-left 0.3s ease;
}
.course-list li:hover { color: var(--white); padding-left: 0.5rem; }
.course-list a {
  color: inherit;
  text-decoration: none;
}
.course-dot {
  width: 8px; height: 8px;
  background: var(--green);
  border-radius: 50%;
  flex-shrink: 0;
}
.academy-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 700;
  color: #000;
  background: var(--green);
  padding: 0.9rem 2rem;
  border-radius: 100px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  position: relative;
  z-index: 1;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  align-self: flex-start;
}
.academy-cta:hover {
  transform: scale(1.06);
  box-shadow: 0 12px 40px rgba(16,185,129,0.4);
}
.academy-cta svg {
  width: 18px; height: 18px;
  stroke: #000; fill: none;
  stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
}

/* Cohort poster: tri-color synthesis identity */
.cohort-poster::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 0% 0%, rgba(255,107,53,0.14), transparent 55%),
    radial-gradient(circle at 100% 0%, rgba(59,130,246,0.12), transparent 55%),
    radial-gradient(circle at 50% 100%, rgba(16,185,129,0.14), transparent 60%);
  pointer-events: none;
}
.cohort-poster::after {
  content: 'COHORT';
  position: absolute;
  bottom: -1.25rem; right: -0.5rem;
  font-family: var(--font-heading);
  font-size: clamp(5rem, 9vw, 8rem);
  font-weight: 700;
  color: rgba(255,255,255,0.025);
  letter-spacing: -0.05em;
  pointer-events: none;
  line-height: 1;
}
.cohort-stripe {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--orange), var(--blue) 50%, var(--green));
}
.cohort-meta-row {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
  position: relative;
  z-index: 1;
}
.cohort-pill {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  padding: 0.35rem 0.7rem;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 4px;
  color: var(--gray-light);
}
.cohort-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 3.6vw, 2.9rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.0;
  margin-bottom: 1.25rem;
  position: relative;
  z-index: 1;
}
.cohort-title .ct-line { display: block; }
.cohort-title .ct-grad {
  background: linear-gradient(90deg, var(--orange), var(--blue) 50%, var(--green));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.cohort-sub {
  font-family: var(--font-mono);
  font-size: clamp(0.95rem, 1.1vw, 1.05rem);
  color: var(--gray-light);
  margin-bottom: 1.75rem;
  line-height: 1.5;
  position: relative;
  z-index: 1;
}
.cohort-axes {
  list-style: none;
  margin-bottom: 2rem;
  position: relative;
  z-index: 1;
  flex: 1;
}
.cohort-axes li {
  font-size: clamp(0.95rem, 1.1vw, 1.05rem);
  padding: 0.8rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  gap: 0.85rem;
  color: var(--gray-light);
}
.axis-dot {
  width: 10px; height: 10px;
  border-radius: 2px;
  flex-shrink: 0;
}
.axis-dot.orange { background: var(--orange); }
.axis-dot.blue { background: var(--blue); }
.axis-dot.green { background: var(--green); }
.axis-label { letter-spacing: 0.01em; }

.cohort-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 700;
  color: #000;
  background: linear-gradient(90deg, var(--orange), var(--green));
  padding: 0.9rem 2rem;
  border-radius: 100px;
  position: relative;
  z-index: 1;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  align-self: flex-start;
}
.cohort-poster:hover .cohort-cta {
  transform: scale(1.06);
  box-shadow: 0 12px 40px rgba(255,107,53,0.35);
}
.cohort-cta svg {
  width: 18px; height: 18px;
  stroke: #000; fill: none;
  stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
}

@media (max-width: 1024px) {
  .teaching-posters { grid-template-columns: 1fr; }
  .section-teaching { padding-bottom: 12rem; }
}
@media (max-width: 768px) {
  .section-teaching { padding: 4rem 1.25rem 8rem; }
  .stats-row { gap: 1.5rem; }
}
</style>
